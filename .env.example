# ============================================================
# Bharat Market Intelligence Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=bharat-market-intelligence
APP_ENV=development
# DEBUG should be false in production
DEBUG=true
LOG_LEVEL=INFO

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bharat_market_intel
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/bharat_market_intel

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Groq LLM API Keys (up to 10, rotate server-side) ---
# Format: comma-separated key:alias pairs
# Example: gsk_abc123:key1,gsk_def456:key2
GROQ_API_KEYS=

# --- Groq Model Configuration ---
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_RPM_LIMIT=30
GROQ_TPM_LIMIT=6000
GROQ_DAILY_TOKEN_LIMIT=500000

# --- Local LLM Fallback (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Embeddings ---
EMBEDDING_PROVIDER=local
# Options: openai, local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
# If using OpenAI embeddings:
OPENAI_API_KEY=

# --- Supabase (for Auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redpanda / Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=bharat-intel-workers

# --- Langfuse (Observability) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# --- Rate Limits ---
ANON_DAILY_CHAT_LIMIT=5
FREE_DAILY_CHAT_LIMIT=20
FREE_DAILY_DEEP_RESEARCH_LIMIT=5
MAX_WATCHLIST_COMPANIES=10

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:5500

# --- Server ---
HOST=127.0.0.1
PORT=8000
WORKERS=1
